<?xml version="1.0" encoding="utf-8"?>
<!--Besiege machine save file.-->
<Machine version="1" bsgVersion="1.4" name="zgvzvqfo_rfd_sim_3">
    <!--The machine's position and rotation.-->
    <Global>
        <Position x="-6.822240035377773e-16" y="5.0" z="2.7675124671815496e-16" />
        <Rotation x="0" y="0" z="0" w="1" />
    </Global>
    <!--The machine's additional data or modded data.-->
    <Data>
        <StringArray key="lua_files">LuaRoot/main.lua</StringArray>
        <StringArray key="lua_data">-- Created 21/01/2026 22:56:51
local frame_count = 0
local refresh_rate = 25
local ballast_ref_key = "Ballast_b99b7f2b"
local mass_min = 5.0
local mass_max = 50.0
local ramp_duration = 2.0
-- Start of the control configuration
local uparrow = machine.new_key_emulator('UpArrow')
local rightarrow = machine.new_key_emulator('RightArrow')
local alpha1 = machine.new_key_emulator('Alpha1')
local downarrow = machine.new_key_emulator('DownArrow')
-- End of the control configuration
local function play()
  ballast_control = machine.get_refs_control(ballast_ref_key)
  end
local function update()
  end
local function late_update()
  end
local function fixed_update()
  -- frame-rate independent update (called 100 times per second)
  frame_count = frame_count + 1
  current_time = frame_count / 100
  -- Start of the control sequence
  local t = math.max(math.min((current_time - 0.5) / ramp_duration, 1.0), 0.005)
  mass_value = mass_min + (mass_max - mass_min) * t
  ballast_control.set_slider("mass", mass_value)
  if current_time  &gt;= 0.9 then alpha1.start() end
  if current_time  &gt;= 1.1 then alpha1.stop() end
  if current_time  &gt;= 1.1 then uparrow.start() end
  if current_time  &gt;= 2.0 then uparrow.stop() end
  if current_time  &gt;= 1.2 then rightarrow.start() end
  if current_time  &gt;= 1.9 then rightarrow.stop() end
  if current_time  &gt;= 2.3 then uparrow.start() end
  if current_time  &gt;= 3.3 then uparrow.stop() end
  if current_time  &gt;= 2.4 then rightarrow.start() end
  if current_time  &gt;= 3.2 then rightarrow.stop() end
  if current_time  &gt;= 3.7 then uparrow.start() end
  if current_time  &gt;= 4.7 then uparrow.stop() end
  if current_time  &gt;= 3.8 then rightarrow.start() end
  if current_time  &gt;= 4.6 then rightarrow.stop() end
  if current_time  &gt;= 5.1 then uparrow.start() end
  if current_time  &gt;= 6.3 then uparrow.stop() end
  if current_time  &gt;= 5.2 then rightarrow.start() end
  if current_time  &gt;= 6.2 then rightarrow.stop() end
  if current_time  &gt;= 6.8 then uparrow.start() end
  if current_time  &gt;= 8.0 then uparrow.stop() end
  if current_time  &gt;= 6.9 then rightarrow.start() end
  if current_time  &gt;= 8.1 then rightarrow.stop() end
  if current_time  &gt;= 8.3 then downarrow.start() end
  if current_time  &gt;= 8.8 then downarrow.stop() end
  -- End of the control sequence
  -- Print the position of the starting block every 1/5 seconds
  if frame_count % (100 / refresh_rate) == 0 then
    machine_info = machine.get_machine_info()
    block_1 = machine_info.get_block_info(0)
    position_1 = block_1.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_1", position_1.x, position_1.y, position_1.z))
    block_7 = machine_info.get_block_info("Wheel_6f89ad90")
    position_7 = block_7.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_7", position_7.x, position_7.y, position_7.z))
    block_10 = machine_info.get_block_info("Wheel_f2903bf7")
    position_10 = block_10.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_10", position_10.x, position_10.y, position_10.z))
    block_13 = machine_info.get_block_info("Wheel_cea55773")
    position_13 = block_13.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_13", position_13.x, position_13.y, position_13.z))
    block_4 = machine_info.get_block_info("Wheel_52de2e04")
    position_4 = block_4.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_4", position_4.x, position_4.y, position_4.z))
    block_Ballast = machine_info.get_block_info("Ballast_b99b7f2b")
    position_Ballast = block_Ballast.position()
    print(string.format("%.1f, %s, %.1f", current_time, "ID_Ballast", mass_value))
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_Ballast", position_Ballast.x, position_Ballast.y, position_Ballast.z))
    end
  end
local function on_gui()
  end
return {play = play, update = update, late_update = late_update, fixed_update = fixed_update, on_gui = on_gui} 
