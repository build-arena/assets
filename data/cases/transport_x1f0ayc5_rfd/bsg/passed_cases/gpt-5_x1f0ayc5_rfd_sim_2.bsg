<?xml version="1.0" encoding="utf-8"?>
<!--Besiege machine save file.-->
<Machine version="1" bsgVersion="1.4" name="x1f0ayc5_rfd_sim_2">
    <!--The machine's position and rotation.-->
    <Global>
        <Position x="-0.0" y="5.0" z="-1.620325495398877e-16" />
        <Rotation x="0" y="0" z="0" w="1" />
    </Global>
    <!--The machine's additional data or modded data.-->
    <Data>
        <StringArray key="lua_files">LuaRoot/main.lua</StringArray>
        <StringArray key="lua_data">-- Created 21/01/2026 21:52:25
local frame_count = 0
local refresh_rate = 25
local ballast_ref_key = "Ballast_64c9cbf6"
local mass_min = 5.0
local mass_max = 50.0
local ramp_duration = 2.0
-- Start of the control configuration
local uparrow = machine.new_key_emulator('UpArrow')
local alpha8 = machine.new_key_emulator('Alpha8')
local alpha1 = machine.new_key_emulator('Alpha1')
local rightarrow = machine.new_key_emulator('RightArrow')
local downarrow = machine.new_key_emulator('DownArrow')
local alpha7 = machine.new_key_emulator('Alpha7')
local alpha2 = machine.new_key_emulator('Alpha2')
local leftarrow = machine.new_key_emulator('LeftArrow')
-- End of the control configuration
local function play()
  ballast_control = machine.get_refs_control(ballast_ref_key)
  end
local function update()
  end
local function late_update()
  end
local function fixed_update()
  -- frame-rate independent update (called 100 times per second)
  frame_count = frame_count + 1
  current_time = frame_count / 100
  -- Start of the control sequence
  local t = math.max(math.min((current_time - 0.5) / ramp_duration, 1.0), 0.005)
  mass_value = mass_min + (mass_max - mass_min) * t
  ballast_control.set_slider("mass", mass_value)
  if current_time  &gt;= 1.0 then leftarrow.start() end
  if current_time  &gt;= 1.3 then leftarrow.stop() end
  if current_time  &gt;= 1.4 then uparrow.start() end
  if current_time  &gt;= 2.8 then uparrow.stop() end
  if current_time  &gt;= 2.8 then uparrow.start() end
  if current_time  &gt;= 3.7 then uparrow.stop() end
  if current_time  &gt;= 3.7 then downarrow.start() end
  if current_time  &gt;= 3.9 then downarrow.stop() end
  -- End of the control sequence
  -- Print the position of the starting block every 1/5 seconds
  if frame_count % (100 / refresh_rate) == 0 then
    machine_info = machine.get_machine_info()
    block_1 = machine_info.get_block_info(0)
    position_1 = block_1.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_1", position_1.x, position_1.y, position_1.z))
    block_50 = machine_info.get_block_info("Wheel_fb59a2ec")
    position_50 = block_50.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_50", position_50.x, position_50.y, position_50.z))
    block_51 = machine_info.get_block_info("Wheel_d4079b8a")
    position_51 = block_51.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_51", position_51.x, position_51.y, position_51.z))
    block_52 = machine_info.get_block_info("Wheel_f9469dcc")
    position_52 = block_52.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_52", position_52.x, position_52.y, position_52.z))
    block_53 = machine_info.get_block_info("Wheel_0f96b24e")
    position_53 = block_53.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_53", position_53.x, position_53.y, position_53.z))
    block_Ballast = machine_info.get_block_info("Ballast_64c9cbf6")
    position_Ballast = block_Ballast.position()
    print(string.format("%.1f, %s, %.1f", current_time, "ID_Ballast", mass_value))
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_Ballast", position_Ballast.x, position_Ballast.y, position_Ballast.z))
    end
  end
local function on_gui()
  end
return {play = play, update = update, late_update = late_update, fixed_update = fixed_update, on_gui = on_gui} 
