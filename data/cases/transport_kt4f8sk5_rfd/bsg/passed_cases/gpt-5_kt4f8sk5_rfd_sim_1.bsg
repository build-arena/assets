<?xml version="1.0" encoding="utf-8"?>
<!--Besiege machine save file.-->
<Machine version="1" bsgVersion="1.4" name="kt4f8sk5_rfd_sim_1">
    <!--The machine's position and rotation.-->
    <Global>
        <Position x="0.01162790697674398" y="5.0" z="-0.03488372093023038" />
        <Rotation x="0" y="0" z="0" w="1" />
    </Global>
    <!--The machine's additional data or modded data.-->
    <Data>
        <StringArray key="lua_files">LuaRoot/main.lua</StringArray>
        <StringArray key="lua_data">-- Created 22/01/2026 01:27:36
local frame_count = 0
local refresh_rate = 25
local ballast_ref_key = "Ballast_bff439d7"
local mass_min = 5.0
local mass_max = 50.0
local ramp_duration = 2.0
-- Start of the control configuration
local downarrow = machine.new_key_emulator('DownArrow')
local leftarrow = machine.new_key_emulator('LeftArrow')
local rightarrow = machine.new_key_emulator('RightArrow')
local uparrow = machine.new_key_emulator('UpArrow')
-- End of the control configuration
local function play()
  ballast_control = machine.get_refs_control(ballast_ref_key)
  end
local function update()
  end
local function late_update()
  end
local function fixed_update()
  -- frame-rate independent update (called 100 times per second)
  frame_count = frame_count + 1
  current_time = frame_count / 100
  -- Start of the control sequence
  local t = math.max(math.min((current_time - 0.5) / ramp_duration, 1.0), 0.005)
  mass_value = mass_min + (mass_max - mass_min) * t
  ballast_control.set_slider("mass", mass_value)
  if current_time  &gt;= 0.0 then uparrow.start() end
  if current_time  &gt;= 0.0 then uparrow.stop() end
  if current_time  &gt;= 2.0 then uparrow.start() end
  if current_time  &gt;= 2.2 then uparrow.stop() end
  if current_time  &gt;= 2.2 then rightarrow.start() end
  if current_time  &gt;= 2.6 then rightarrow.stop() end
  if current_time  &gt;= 2.6 then uparrow.start() end
  if current_time  &gt;= 4.2 then uparrow.stop() end
  if current_time  &gt;= 4.2 then rightarrow.start() end
  if current_time  &gt;= 4.9 then rightarrow.stop() end
  if current_time  &gt;= 5.0 then uparrow.start() end
  if current_time  &gt;= 6.5 then uparrow.stop() end
  -- End of the control sequence
  -- Print the position of the starting block every 1/5 seconds
  if frame_count % (100 / refresh_rate) == 0 then
    machine_info = machine.get_machine_info()
    block_1 = machine_info.get_block_info(0)
    position_1 = block_1.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_1", position_1.x, position_1.y, position_1.z))
    block_36 = machine_info.get_block_info("Wheel_930e96ce")
    position_36 = block_36.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_36", position_36.x, position_36.y, position_36.z))
    block_37 = machine_info.get_block_info("Wheel_4a6c66ff")
    position_37 = block_37.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_37", position_37.x, position_37.y, position_37.z))
    block_38 = machine_info.get_block_info("Wheel_d5a1b593")
    position_38 = block_38.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_38", position_38.x, position_38.y, position_38.z))
    block_39 = machine_info.get_block_info("Wheel_b0d85dee")
    position_39 = block_39.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_39", position_39.x, position_39.y, position_39.z))
    block_Ballast = machine_info.get_block_info("Ballast_bff439d7")
    position_Ballast = block_Ballast.position()
    print(string.format("%.1f, %s, %.1f", current_time, "ID_Ballast", mass_value))
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_Ballast", position_Ballast.x, position_Ballast.y, position_Ballast.z))
    end
  end
local function on_gui()
  end
return {play = play, update = update, late_update = late_update, fixed_update = fixed_update, on_gui = on_gui} 
