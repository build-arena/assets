<?xml version="1.0" encoding="utf-8"?>
<!--Besiege machine save file.-->
<Machine version="1" bsgVersion="1.4" name="s936utai_sim_3">
    <!--The machine's position and rotation.-->
    <Global>
        <Position x="0.075" y="5.0" z="0.125" />
        <Rotation x="0" y="0" z="0" w="1" />
    </Global>
    <!--The machine's additional data or modded data.-->
    <Data>
        <StringArray key="lua_files">LuaRoot/main.lua</StringArray>
        <StringArray key="lua_data">-- Created 21/01/2026 23:26:30
local frame_count = 0
local refresh_rate = 25
local ballast_ref_key = "Ballast_ec4239a8"
local mass_min = 5.0
local mass_max = 50.0
local ramp_duration = 2.0
-- Start of the control configuration
local rightarrow = machine.new_key_emulator('RightArrow')
local uparrow = machine.new_key_emulator('UpArrow')
-- End of the control configuration
local function play()
  ballast_control = machine.get_refs_control(ballast_ref_key)
  end
local function update()
  end
local function late_update()
  end
local function fixed_update()
  -- frame-rate independent update (called 100 times per second)
  frame_count = frame_count + 1
  current_time = frame_count / 100
  -- Start of the control sequence
  local t = math.max(math.min((current_time - 0.5) / ramp_duration, 1.0), 0.005)
  mass_value = mass_min + (mass_max - mass_min) * t
  ballast_control.set_slider("mass", mass_value)
  if current_time  &gt;= 1.0 then uparrow.start() end
  if current_time  &gt;= 1.0 then uparrow.stop() end
  if current_time  &gt;= 1.2 then rightarrow.start() end
  if current_time  &gt;= 1.4 then rightarrow.stop() end
  if current_time  &gt;= 1.4 then uparrow.start() end
  if current_time  &gt;= 1.7 then uparrow.stop() end
  if current_time  &gt;= 1.7 then rightarrow.start() end
  if current_time  &gt;= 1.9 then rightarrow.stop() end
  if current_time  &gt;= 2.0 then uparrow.start() end
  if current_time  &gt;= 2.2 then uparrow.stop() end
  if current_time  &gt;= 2.3 then rightarrow.start() end
  if current_time  &gt;= 2.4 then rightarrow.stop() end
  if current_time  &gt;= 2.5 then uparrow.start() end
  if current_time  &gt;= 2.7 then uparrow.stop() end
  if current_time  &gt;= 2.7 then rightarrow.start() end
  if current_time  &gt;= 2.9 then rightarrow.stop() end
  if current_time  &gt;= 3.0 then uparrow.start() end
  if current_time  &gt;= 3.2 then uparrow.stop() end
  if current_time  &gt;= 3.2 then rightarrow.start() end
  if current_time  &gt;= 3.4 then rightarrow.stop() end
  if current_time  &gt;= 3.4 then uparrow.start() end
  if current_time  &gt;= 3.6 then uparrow.stop() end
  if current_time  &gt;= 3.7 then rightarrow.start() end
  if current_time  &gt;= 3.8 then rightarrow.stop() end
  if current_time  &gt;= 3.9 then uparrow.start() end
  if current_time  &gt;= 4.1 then uparrow.stop() end
  if current_time  &gt;= 4.1 then rightarrow.start() end
  if current_time  &gt;= 4.2 then rightarrow.stop() end
  if current_time  &gt;= 4.3 then uparrow.start() end
  if current_time  &gt;= 4.5 then uparrow.stop() end
  if current_time  &gt;= 4.5 then rightarrow.start() end
  if current_time  &gt;= 4.6 then rightarrow.stop() end
  if current_time  &gt;= 4.7 then uparrow.start() end
  if current_time  &gt;= 4.9 then uparrow.stop() end
  if current_time  &gt;= 4.9 then rightarrow.start() end
  if current_time  &gt;= 5.0 then rightarrow.stop() end
  if current_time  &gt;= 5.1 then uparrow.start() end
  if current_time  &gt;= 5.2 then uparrow.stop() end
  if current_time  &gt;= 5.3 then rightarrow.start() end
  if current_time  &gt;= 5.4 then rightarrow.stop() end
  if current_time  &gt;= 5.5 then uparrow.start() end
  if current_time  &gt;= 5.6 then uparrow.stop() end
  -- End of the control sequence
  -- Print the position of the starting block every 1/5 seconds
  if frame_count % (100 / refresh_rate) == 0 then
    machine_info = machine.get_machine_info()
    block_1 = machine_info.get_block_info(0)
    position_1 = block_1.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_1", position_1.x, position_1.y, position_1.z))
    block_Ballast = machine_info.get_block_info("Ballast_ec4239a8")
    position_Ballast = block_Ballast.position()
    print(string.format("%.1f, %s, %.1f", current_time, "ID_Ballast", mass_value))
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_Ballast", position_Ballast.x, position_Ballast.y, position_Ballast.z))
    end
  end
local function on_gui()
  end
return {play = play, update = update, late_update = late_update, fixed_update = fixed_update, on_gui = on_gui} 
