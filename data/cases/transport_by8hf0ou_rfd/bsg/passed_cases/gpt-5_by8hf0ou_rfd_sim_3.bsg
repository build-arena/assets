<?xml version="1.0" encoding="utf-8"?>
<!--Besiege machine save file.-->
<Machine version="1" bsgVersion="1.4" name="by8hf0ou_rfd_sim_3">
    <!--The machine's position and rotation.-->
    <Global>
        <Position x="1.09923071745065e-15" y="5.0" z="8.134307309134811e-16" />
        <Rotation x="0" y="0" z="0" w="1" />
    </Global>
    <!--The machine's additional data or modded data.-->
    <Data>
        <StringArray key="lua_files">LuaRoot/main.lua</StringArray>
        <StringArray key="lua_data">-- Created 22/01/2026 04:06:04
local frame_count = 0
local refresh_rate = 25
local ballast_ref_key = "Ballast_290a2402"
local mass_min = 5.0
local mass_max = 50.0
local ramp_duration = 2.0
-- Start of the control configuration
local alpha5 = machine.new_key_emulator('Alpha5')
local alpha6 = machine.new_key_emulator('Alpha6')
local alpha9 = machine.new_key_emulator('Alpha9')
local leftarrow = machine.new_key_emulator('LeftArrow')
local rightarrow = machine.new_key_emulator('RightArrow')
-- End of the control configuration
local function play()
  ballast_control = machine.get_refs_control(ballast_ref_key)
  end
local function update()
  end
local function late_update()
  end
local function fixed_update()
  -- frame-rate independent update (called 100 times per second)
  frame_count = frame_count + 1
  current_time = frame_count / 100
  -- Start of the control sequence
  local t = math.max(math.min((current_time - 0.5) / ramp_duration, 1.0), 0.005)
  mass_value = mass_min + (mass_max - mass_min) * t
  ballast_control.set_slider("mass", mass_value)
  if current_time  &gt;= 1.2 then leftarrow.start() end
  if current_time  &gt;= 1.5 then leftarrow.stop() end
  if current_time  &gt;= 1.5 then alpha5.start() end
  if current_time  &gt;= 2.9 then alpha5.stop() end
  if current_time  &gt;= 1.5 then alpha6.start() end
  if current_time  &gt;= 2.9 then alpha6.stop() end
  if current_time  &gt;= 2.9 then alpha9.start() end
  if current_time  &gt;= 3.1 then alpha9.stop() end
  if current_time  &gt;= 3.1 then leftarrow.start() end
  if current_time  &gt;= 3.9 then leftarrow.stop() end
  if current_time  &gt;= 3.9 then alpha5.start() end
  if current_time  &gt;= 5.3 then alpha5.stop() end
  if current_time  &gt;= 3.9 then alpha6.start() end
  if current_time  &gt;= 5.3 then alpha6.stop() end
  if current_time  &gt;= 5.3 then alpha9.start() end
  if current_time  &gt;= 5.4 then alpha9.stop() end
  -- End of the control sequence
  -- Print the position of the starting block every 1/5 seconds
  if frame_count % (100 / refresh_rate) == 0 then
    machine_info = machine.get_machine_info()
    block_1 = machine_info.get_block_info(0)
    position_1 = block_1.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_1", position_1.x, position_1.y, position_1.z))
    block_94 = machine_info.get_block_info("Wheel_3898c4c1")
    position_94 = block_94.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_94", position_94.x, position_94.y, position_94.z))
    block_95 = machine_info.get_block_info("Wheel_93e02646")
    position_95 = block_95.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_95", position_95.x, position_95.y, position_95.z))
    block_96 = machine_info.get_block_info("Wheel_1f896861")
    position_96 = block_96.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_96", position_96.x, position_96.y, position_96.z))
    block_99 = machine_info.get_block_info("Wheel_6a2792cf")
    position_99 = block_99.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_99", position_99.x, position_99.y, position_99.z))
    block_100 = machine_info.get_block_info("Wheel_9c0da4d3")
    position_100 = block_100.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_100", position_100.x, position_100.y, position_100.z))
    block_101 = machine_info.get_block_info("Wheel_54905c14")
    position_101 = block_101.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_101", position_101.x, position_101.y, position_101.z))
    block_Ballast = machine_info.get_block_info("Ballast_290a2402")
    position_Ballast = block_Ballast.position()
    print(string.format("%.1f, %s, %.1f", current_time, "ID_Ballast", mass_value))
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_Ballast", position_Ballast.x, position_Ballast.y, position_Ballast.z))
    end
  end
local function on_gui()
  end
return {play = play, update = update, late_update = late_update, fixed_update = fixed_update, on_gui = on_gui} 
