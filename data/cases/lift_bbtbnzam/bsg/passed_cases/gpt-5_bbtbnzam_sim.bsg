    <Data>
        <StringArray key="lua_files">LuaRoot/main.lua</StringArray>
        <StringArray key="lua_data">-- Created 24/01/2026 16:05:27
local frame_count = 0
local refresh_rate = 25
-- Start of the control configuration
local alpha1 = machine.new_key_emulator('Alpha1')
-- End of the control configuration
local function play()
  end
local function update()
  end
local function late_update()
  end
local function fixed_update()
  -- frame-rate independent update (called 100 times per second)
  frame_count = frame_count + 1
  current_time = frame_count / 100
  -- Start of the control sequence
  if current_time  &gt;= 2.0 then alpha1.start() end
  if current_time  &gt;= 32.0 then alpha1.stop() end
  -- End of the control sequence
  -- Print the position of the starting block every 1/5 seconds
  if frame_count % (100 / refresh_rate) == 0 then
    machine_info = machine.get_machine_info()
    block_A_8 = machine_info.get_block_info("SingleWoodenBlock_ea141e75")
    position_A_8 = block_A_8.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_A_8", position_A_8.x, position_A_8.y, position_A_8.z))
    block_A_13 = machine_info.get_block_info("SingleWoodenBlock_7f50bf01")
    position_A_13 = block_A_13.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_A_13", position_A_13.x, position_A_13.y, position_A_13.z))
    block_A_17 = machine_info.get_block_info("Brace_1d5badd3")
    position_A_17 = block_A_17.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_A_17", position_A_17.x, position_A_17.y, position_A_17.z))
    block_3 = machine_info.get_block_info("WaterCannon_f96391bf")
    position_3 = block_3.position()
    burn_3 = block_3.burning()
    print(string.format("%.1f, %s, %s", current_time, "ID_3", tostring(burn_3)))
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_3", position_3.x, position_3.y, position_3.z))
    end
  end
local function on_gui()
  end
return {play = play, update = update, late_update = late_update, fixed_update = fixed_update, on_gui = on_gui} 
