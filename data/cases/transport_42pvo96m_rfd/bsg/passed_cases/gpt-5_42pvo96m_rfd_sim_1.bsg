<?xml version="1.0" encoding="utf-8"?>
<!--Besiege machine save file.-->
<Machine version="1" bsgVersion="1.4" name="42pvo96m_rfd_sim_1">
    <!--The machine's position and rotation.-->
    <Global>
        <Position x="2.4810273211458044e-15" y="5.0" z="4.3161067006915175e-15" />
        <Rotation x="0" y="0" z="0" w="1" />
    </Global>
    <!--The machine's additional data or modded data.-->
    <Data>
        <StringArray key="lua_files">LuaRoot/main.lua</StringArray>
        <StringArray key="lua_data">-- Created 22/01/2026 01:33:38
local frame_count = 0
local refresh_rate = 25
local ballast_ref_key = "Ballast_6dedc999"
local mass_min = 5.0
local mass_max = 50.0
local ramp_duration = 2.0
-- Start of the control configuration
local leftarrow = machine.new_key_emulator('LeftArrow')
local uparrow = machine.new_key_emulator('UpArrow')
local downarrow = machine.new_key_emulator('DownArrow')
local rightarrow = machine.new_key_emulator('RightArrow')
-- End of the control configuration
local function play()
  ballast_control = machine.get_refs_control(ballast_ref_key)
  end
local function update()
  end
local function late_update()
  end
local function fixed_update()
  -- frame-rate independent update (called 100 times per second)
  frame_count = frame_count + 1
  current_time = frame_count / 100
  -- Start of the control sequence
  local t = math.max(math.min((current_time - 0.5) / ramp_duration, 1.0), 0.005)
  mass_value = mass_min + (mass_max - mass_min) * t
  ballast_control.set_slider("mass", mass_value)
  if current_time  &gt;= 0.6 then rightarrow.start() end
  if current_time  &gt;= 0.9 then rightarrow.stop() end
  if current_time  &gt;= 0.6 then rightarrow.start() end
  if current_time  &gt;= 0.9 then rightarrow.stop() end
  if current_time  &gt;= 0.9 then uparrow.start() end
  if current_time  &gt;= 2.5 then uparrow.stop() end
  if current_time  &gt;= 2.6 then downarrow.start() end
  if current_time  &gt;= 2.7 then downarrow.stop() end
  if current_time  &gt;= 2.7 then rightarrow.start() end
  if current_time  &gt;= 3.9 then rightarrow.stop() end
  if current_time  &gt;= 4.0 then uparrow.start() end
  if current_time  &gt;= 5.6 then uparrow.stop() end
  if current_time  &gt;= 5.6 then downarrow.start() end
  if current_time  &gt;= 5.7 then downarrow.stop() end
  if current_time  &gt;= 5.7 then leftarrow.start() end
  if current_time  &gt;= 6.0 then leftarrow.stop() end
  -- End of the control sequence
  -- Print the position of the starting block every 1/5 seconds
  if frame_count % (100 / refresh_rate) == 0 then
    machine_info = machine.get_machine_info()
    block_1 = machine_info.get_block_info(0)
    position_1 = block_1.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_1", position_1.x, position_1.y, position_1.z))
    block_110 = machine_info.get_block_info("Wheel_68e5fe31")
    position_110 = block_110.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_110", position_110.x, position_110.y, position_110.z))
    block_112 = machine_info.get_block_info("Wheel_9e25658f")
    position_112 = block_112.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_112", position_112.x, position_112.y, position_112.z))
    block_114 = machine_info.get_block_info("Wheel_cb7af359")
    position_114 = block_114.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_114", position_114.x, position_114.y, position_114.z))
    block_116 = machine_info.get_block_info("Wheel_741ea0f8")
    position_116 = block_116.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_116", position_116.x, position_116.y, position_116.z))
    block_118 = machine_info.get_block_info("Wheel_11b42214")
    position_118 = block_118.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_118", position_118.x, position_118.y, position_118.z))
    block_120 = machine_info.get_block_info("Wheel_ed43c516")
    position_120 = block_120.position()
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_120", position_120.x, position_120.y, position_120.z))
    block_Ballast = machine_info.get_block_info("Ballast_6dedc999")
    position_Ballast = block_Ballast.position()
    print(string.format("%.1f, %s, %.1f", current_time, "ID_Ballast", mass_value))
    print(string.format("%.1f, %s, %.1f, %.1f, %.1f", current_time, "ID_Ballast", position_Ballast.x, position_Ballast.y, position_Ballast.z))
    end
  end
local function on_gui()
  end
return {play = play, update = update, late_update = late_update, fixed_update = fixed_update, on_gui = on_gui} 
